---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="blog-index">
			<header class="page-heading">
				<p>WRITING</p>
				<h1>文章</h1>
				<span>关于技术、工程和学习方法的长期记录。</span>
			</header>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<Image width={960} height={480} src={post.data.heroImage} alt="文章封面" />
								)}
								<div class="post-copy">
									<p><FormattedDate date={post.data.pubDate} /></p>
									<h2>{post.data.title}</h2>
									<span>{post.data.description}</span>
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-index {
		width: min(960px, calc(100% - 2rem));
		max-width: none;
	}
	.page-heading {
		padding: 2rem 0 4rem;
	}
	.page-heading p {
		margin: 0;
		color: var(--accent);
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.18em;
	}
	.page-heading h1 {
		margin: 0.3rem 0 0.7rem;
		font-size: clamp(3.2rem, 8vw, 6rem);
		letter-spacing: -0.06em;
	}
	.page-heading span {
		color: rgb(var(--gray));
	}
	.post-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.post-list li {
		margin-bottom: 2rem;
	}
	.post-list a {
		display: grid;
		grid-template-columns: minmax(260px, 0.85fr) 1fr;
		overflow: hidden;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 22px;
		background: white;
		color: inherit;
		text-decoration: none;
		transition: transform 180ms ease, box-shadow 180ms ease;
	}
	.post-list a:hover {
		transform: translateY(-3px);
		box-shadow: var(--box-shadow);
	}
	.post-list :global(img) {
		width: 100%;
		height: 100%;
		min-height: 270px;
		border-radius: 0;
		object-fit: cover;
	}
	.post-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 2rem;
	}
	.post-copy p,
	.post-copy span {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.88rem;
	}
	.post-copy h2 {
		margin: 0.8rem 0;
		font-size: clamp(1.6rem, 3vw, 2.3rem);
	}
	@media (max-width: 700px) {
		.post-list a {
			grid-template-columns: 1fr;
		}
		.post-list :global(img) {
			min-height: 210px;
		}
	}
</style>
