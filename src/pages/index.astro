---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPost = posts[0];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="hero">
				<p class="eyebrow">THINK · BUILD · SHARE</p>
				<h1>朝花夕拾</h1>
				<p class="intro">
					你好，我是 sjmshsh。这里记录 AI 基础设施、工程实践，以及那些值得反复回看的学习过程。
				</p>
				<div class="actions">
					<a class="primary" href="/blog">阅读文章</a>
					<a class="secondary" href="/about">关于本站</a>
				</div>
			</section>

			{
				latestPost && (
					<section class="latest" aria-labelledby="latest-heading">
						<div class="section-heading">
							<div>
								<p class="eyebrow">LATEST NOTE</p>
								<h2 id="latest-heading">最新文章</h2>
							</div>
							<a href="/blog">查看全部 →</a>
						</div>
						<a class="article-card" href={`/blog/${latestPost.id}/`}>
							{latestPost.data.heroImage && (
								<Image
									src={latestPost.data.heroImage}
									width={960}
									height={480}
									alt="文章封面"
								/>
							)}
							<div class="article-copy">
								<p class="article-date"><FormattedDate date={latestPost.data.pubDate} /></p>
								<h3>{latestPost.data.title}</h3>
								<p>{latestPost.data.description}</p>
								<span>阅读全文 →</span>
							</div>
						</a>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.home {
		width: min(1120px, calc(100% - 2rem));
		max-width: none;
		padding-top: 5.5rem;
	}
	.hero {
		max-width: 900px;
		padding: 3rem 0 7rem;
	}
	.eyebrow {
		margin: 0 0 1rem;
		color: var(--accent);
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.18em;
	}
	.hero h1 {
		max-width: 900px;
		margin: 0;
		font-size: clamp(3rem, 8vw, 6.8rem);
		letter-spacing: -0.065em;
		line-height: 0.98;
	}
	.intro {
		max-width: 700px;
		margin: 2rem 0 0;
		color: rgb(var(--gray-dark));
		font-size: clamp(1.08rem, 2vw, 1.35rem);
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}
	.actions a {
		padding: 0.7rem 1.1rem;
		border-radius: 999px;
		font-size: 0.95rem;
		font-weight: 700;
		text-decoration: none;
	}
	.primary {
		background: rgb(var(--black));
		color: white;
	}
	.primary:hover {
		background: var(--accent);
		color: white;
	}
	.secondary {
		border: 1px solid rgb(var(--gray-light));
		color: rgb(var(--black));
	}
	.latest {
		padding: 0 0 4rem;
	}
	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		margin-bottom: 1.5rem;
	}
	.section-heading h2 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3rem);
	}
	.section-heading > a {
		font-size: 0.95rem;
		font-weight: 700;
		text-decoration: none;
	}
	.article-card {
		display: grid;
		grid-template-columns: 1.25fr 1fr;
		overflow: hidden;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.72);
		color: inherit;
		text-decoration: none;
		transition: transform 180ms ease, box-shadow 180ms ease;
	}
	.article-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--box-shadow);
	}
	.article-card :global(img) {
		width: 100%;
		height: 100%;
		min-height: 330px;
		border-radius: 0;
		object-fit: cover;
	}
	.article-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: clamp(1.5rem, 4vw, 3.5rem);
	}
	.article-date {
		margin: 0 0 1rem;
		color: rgb(var(--gray));
		font-size: 0.85rem;
	}
	.article-copy h3 {
		font-size: clamp(1.6rem, 3vw, 2.5rem);
	}
	.article-copy > p:not(.article-date) {
		color: rgb(var(--gray));
		font-size: 1rem;
	}
	.article-copy span {
		margin-top: 1rem;
		color: var(--accent);
		font-size: 0.95rem;
		font-weight: 700;
	}
	@media (max-width: 760px) {
		.home {
			padding-top: 2.5rem;
		}
		.hero {
			padding: 2rem 0 4.5rem;
		}
		.article-card {
			grid-template-columns: 1fr;
		}
		.article-card :global(img) {
			min-height: 220px;
		}
	}
</style>
